// ESPV builtin definition class (RequiredFeatures follows RVVBuiltin in
// riscv_vector_common.td so that missing-extension errors come from Clang).
class ESPVBuiltin<string builtin_name, string ir_name, code manual_codegen = [{}],
                  list<string> required_features = ["xespv"]> {
  string BuiltinName = builtin_name;
  string IRName = ir_name;
  code ManualCodegen = manual_codegen;
  list<string> RequiredFeatures = required_features;
}


def esp_ld_128_usar_ip_m : ESPVBuiltin<
  "ld_128_usar_ip_m",
  "riscv_esp_ld_128_usar_ip_m",
  [{
      // 1. Get arguments
      Value *Ptr = EmitScalarExpr(E->getArg(0));
      Value *Imm = EmitScalarExpr(E->getArg(1));
      Value *OutVecPtr = EmitScalarExpr(E->getArg(2)); // OutVecPtr - vector output
      Value *OutSarBytesPtr = EmitScalarExpr(E->getArg(3)); // OutSarBytesPtr - SAR_BYTES output

            // 2. Get Intrinsic definition (corresponds to def int_riscv_esp_ld_128_usar_ip_m in .td)
      Function *F = CGM.getIntrinsic(Intrinsic::riscv_esp_ld_128_usar_ip_m);

            // 3. Emit Call instruction; intrinsic return type is { <16 x i8>, i8*, i64 } (vector, pointer, sar_bytes)
      Value *Call = Builder.CreateCall(F, {Ptr, Imm});

            // 4. Extract return values (ExtractValue)
      Value *VecRes = Builder.CreateExtractValue(Call, 0); // Vector result
      Value *NewPtr = Builder.CreateExtractValue(Call, 1); // Updated pointer
      Value *SarBytes = Builder.CreateExtractValue(Call, 2); // SAR_BYTES value

            // 5. Store vector part to user-provided pointer (corresponds to &res.val in wrapper)
      Builder.CreateStore(VecRes, Address(OutVecPtr, VecRes->getType(), 
      CharUnits::fromQuantity(16)));

            // 6. Store SAR_BYTES value to output pointer
      Builder.CreateStore(SarBytes, Address(OutSarBytesPtr, SarBytes->getType(),
      CharUnits::fromQuantity(8)));

            // 7. Return updated pointer
      return NewPtr;
  }]
>;

def esp_ld_128_usar_xp_m : ESPVBuiltin<
  "ld_128_usar_xp_m",
  "riscv_esp_ld_128_usar_xp_m",
  [{
      // Register offset version of ld_128_usar_ip_m
      Value *Ptr = EmitScalarExpr(E->getArg(0));
      Value *Offset = EmitScalarExpr(E->getArg(1)); // Register offset
      Value *OutVecPtr = EmitScalarExpr(E->getArg(2)); // OutVecPtr - vector output
      Value *OutSarBytesPtr = EmitScalarExpr(E->getArg(3)); // OutSarBytesPtr - SAR_BYTES output

      Function *F = CGM.getIntrinsic(Intrinsic::riscv_esp_ld_128_usar_xp_m);
      Value *Call = Builder.CreateCall(F, {Ptr, Offset});

      Value *VecRes = Builder.CreateExtractValue(Call, 0); // Vector result
      Value *NewPtr = Builder.CreateExtractValue(Call, 1); // Updated pointer
      Value *SarBytes = Builder.CreateExtractValue(Call, 2); // SAR_BYTES value

            // Store vector result to output pointer
      Builder.CreateStore(VecRes, Address(OutVecPtr, VecRes->getType(), 
      CharUnits::fromQuantity(16)));

            // Store SAR_BYTES value to output pointer
      Builder.CreateStore(SarBytes, Address(OutSarBytesPtr, SarBytes->getType(),
      CharUnits::fromQuantity(8)));

      return NewPtr;
  }]
>;

def esp_vld_128_ip_m : ESPVBuiltin<
  "vld_128_ip_m",
  "riscv_esp_vld_128_ip_m",
  [{
      // 1. Get arguments
      Value *Ptr = EmitScalarExpr(E->getArg(0));
      Value *Imm = EmitScalarExpr(E->getArg(1));
      Value *OutVecPtr = EmitScalarExpr(E->getArg(2)); // Pointer to val

            // 2. Get Intrinsic definition (corresponds to def int_riscv_esp_vld_128_ip_m in .td)
      Function *F = CGM.getIntrinsic(Intrinsic::riscv_esp_vld_128_ip_m);

            // 3. Emit Call instruction; intrinsic return type is { <16 x i8>, i8* }
      Value *Call = Builder.CreateCall(F, {Ptr, Imm});

            // 4. Extract return values (ExtractValue)
      Value *VecRes = Builder.CreateExtractValue(Call, 0); // Vector part
      Value *NewPtr = Builder.CreateExtractValue(Call, 1); // Pointer part

            // 5. Store vector part to user-provided pointer (corresponds to &res.val in wrapper);
            //    alignment should be set per target; vectors are typically aligned
      Builder.CreateStore(VecRes, Address(OutVecPtr, VecRes->getType(), 
      CharUnits::fromQuantity(16)));

            // 6. Return updated pointer
      return NewPtr;
  }]
>;

