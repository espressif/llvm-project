def esp_vld_h_64_ip_m : ESPVBuiltin<
  "vld_h_64_ip_m",
  "riscv_esp_vld_h_64_ip_m",
  [{
      Value *Ptr = EmitScalarExpr(E->getArg(0));
      Value *Imm = EmitScalarExpr(E->getArg(1));
      Value *OutVecPtr = EmitScalarExpr(E->getArg(2));

      Function *F = CGM.getIntrinsic(Intrinsic::riscv_esp_vld_h_64_ip_m);
      Value *Call = Builder.CreateCall(F, {Ptr, Imm});

      Value *VecRes = Builder.CreateExtractValue(Call, 0);
      Value *NewPtr = Builder.CreateExtractValue(Call, 1);

            // Store to high 64 bits (offset 8) of 128-bit vector
      Value *High64Addr = Builder.CreateConstInBoundsGEP1_32(
      Builder.getInt8Ty(), OutVecPtr, 8);
      Builder.CreateStore(VecRes, Address(High64Addr, VecRes->getType(), 
      CharUnits::fromQuantity(8)));

      return NewPtr;
  }]
>;

