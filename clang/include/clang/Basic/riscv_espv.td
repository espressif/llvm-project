      Value *Call = Builder.CreateCall(F, {QX, QY, QW, RS1, Sel2, UAStateIn, SarBytesIn, SarIn});

      // Extract results: qu (v16i8), qz (v8i16), qv (v8i16), ptr, ua_state_out (v16i8)
      Value *QU = Builder.CreateExtractValue(Call, 0);
